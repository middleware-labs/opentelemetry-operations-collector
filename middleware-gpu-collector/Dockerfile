# CGO-enabled (dcgm/nvml) -> the binary is glibc-linked, so the runtime cannot
# be `scratch`. Use a minimal glibc base instead. This Dockerfile expects the
# otelcol-middleware-gpu binary to already be built in the build context (run
# `make build` first), matching `make image-build`.
FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /etc/otelcol-middleware-gpu && chmod 755 /etc/otelcol-middleware-gpu

ARG USER_UID=10001
USER ${USER_UID}

COPY --chmod=755 otelcol-middleware-gpu /otelcol-middleware-gpu
COPY config.yaml /etc/otelcol-middleware-gpu/config.yaml
ENTRYPOINT ["/otelcol-middleware-gpu"]
CMD ["--config=/etc/otelcol-middleware-gpu/config.yaml"]
