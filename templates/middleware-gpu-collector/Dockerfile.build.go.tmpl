# NOTE: File generated by distrogen from a CUSTOM template
# (templates/middleware-gpu-collector/Dockerfile.build.go.tmpl).
#
# This distribution is built with CGO enabled (required by the dcgm/nvml GPU
# receivers), so the resulting binary is dynamically linked against glibc and
# the dynamic loader. A `FROM scratch` runtime cannot satisfy those, producing
# "exec ...: no such file or directory" at container start. We therefore use a
# minimal glibc-based runtime (debian:bookworm-slim) instead of scratch.
ARG PROJECT_ROOT="."
ARG BUILD_CONTAINER="debian"
ARG RUNTIME_CONTAINER="debian:bookworm-slim"
FROM --platform=${BUILDPLATFORM:-linux/amd64} ${BUILD_CONTAINER} AS build

RUN apt-get update && apt-get install -y make curl{{ if .CollectorCGO }} build-essential{{ end }}

ARG PROJECT_ROOT
COPY ${PROJECT_ROOT} /

WORKDIR /{{ .Name }}

ARG BUILDARCH
ARG BUILDOS
ARG TARGETOS
ARG TARGETARCH
{{ if .CollectorCGO -}}
RUN if [ "${TARGETARCH}" = "arm64" ] && [ "${BUILDARCH}" != "arm64" ]; then \
        apt-get install -y gcc-aarch64-linux-gnu libc6-dev-arm64-cross; \
        CC=aarch64-linux-gnu-gcc; \
    fi && \
    CC=${CC} make build
{{ else -}}
RUN make build
{{ end -}}

# Minimal glibc runtime. ca-certificates is needed for TLS to the OTLP endpoint.
FROM ${RUNTIME_CONTAINER}

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /etc/{{ .BinaryName }} && chmod 755 /etc/{{ .BinaryName }}

ARG USER_UID=10001
USER ${USER_UID}

COPY --from=build --chmod=755 /{{ .Name }}/{{ .BinaryName }} /{{ .BinaryName }}
COPY --from=build --chmod=644 /{{ .Name }}/config.yaml /etc/{{ .BinaryName }}/config.yaml

ENTRYPOINT ["/{{ .BinaryName }}"{{ $length := len .FeatureGates }}{{ if gt $length 0 }}, "--feature-gates={{ .FeatureGates.Render }}"{{ end }}]
CMD ["--config=/etc/{{ .BinaryName }}/config.yaml"]
