# NOTE: File generated by distrogen from a CUSTOM template
# (templates/middleware-gpu-collector/Dockerfile.go.tmpl).
#
# CGO-enabled (dcgm/nvml) -> the binary is glibc-linked, so the runtime cannot
# be `scratch`. Use a minimal glibc base instead. This Dockerfile expects the
# {{ .BinaryName }} binary to already be built in the build context (run
# `make build` first), matching `make image-build`.
FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /etc/{{ .BinaryName }} && chmod 755 /etc/{{ .BinaryName }}

ARG USER_UID=10001
USER ${USER_UID}

COPY --chmod=755 {{ .BinaryName }} /{{ .BinaryName }}
COPY config.yaml /etc/{{ .BinaryName }}/config.yaml
ENTRYPOINT ["/{{ .BinaryName }}"{{ $length := len .FeatureGates }}{{ if gt $length 0 }}, "--feature-gates={{ .FeatureGates.Render }}"{{ end }}]
CMD ["--config=/etc/{{ .BinaryName }}/config.yaml"]
